{
  "expo": {
    "name": "Batumionline",
    "slug": "batumionline-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "batumionline",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.batumionline.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F3ED"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.batumionline.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
