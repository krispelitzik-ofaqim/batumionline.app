{
  "expo": {
    "name": "Batumionline",
    "slug": "batumionline-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "batumionline",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.batumionline.app",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F3ED"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.batumionline.batumi"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09ed4232-19dd-41d6-8b2b-4ddb7e25cee5"
      }
    },
    "owner": "krispel"
  }
}
